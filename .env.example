# 飞书应用凭证（在 https://open.feishu.cn 创建企业自建应用后获取）
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# 抖音认证（二选一）
# 方式一: 导出 Cookie（登录后从浏览器复制，或运行 `python main.py login` 自动抓取）
DOUYIN_COOKIE=
# 方式二: 连接已登录的 Chrome（推荐，更优雅 —— 不导出 Cookie，直接复用浏览器登录态）
# 启动 Chrome: chrome --remote-debugging-port=9222，登录抖音后填写端点：
# CDP_ENDPOINT=http://localhost:9222

# --- 作者主页 ---
# 用 scrape-author 时通过命令行传主页 URL；复用已有表时在这里配置：
# DOUYIN_AUTHOR_URL=https://www.douyin.com/user/MS4wLjABAAAA...
AUTHOR_RECENT_COUNT=5    # 跳过置顶后保留的作品数量（默认最近 5 条）
AUTHOR_TOP_SKIP=3        # 检测不到 is_top 置顶标记时，回退跳过的前 N 条（3 => 取第4-8条）

# --- 复用已有多维表格时才需要（scrape-author 会自动新建，无需填）---
# FEISHU_APP_TOKEN=your_bitable_app_token
# AUTHOR_TABLE_ID=your_author_table_id       # 作者信息（粉丝量等）
# VIDEO_TABLE_ID=your_video_table_id         # 视频作品
# IMAGE_TABLE_ID=your_image_table_id         # 图文作品
# COMMENT_L1_TABLE_ID=your_comment_l1_table_id   # 一级评论
# COMMENT_L2_TABLE_ID=your_comment_l2_table_id   # 二级评论

# 代理（可选）
# PROXY_URL=http://127.0.0.1:7890

# 爬取 / 限流配置
MAX_PAGES=10
REQUEST_DELAY=2
REQUEST_JITTER=0.4
REQUEST_MAX_RETRIES=3
EMPTY_RETRY=2
BACKOFF_FACTOR=2.0
BACKOFF_MAX=30
